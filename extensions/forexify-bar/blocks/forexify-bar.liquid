{% comment %}
  Forexify Exchange Rate Bar
  Displays ECB exchange rates in storefront
{% endcomment %}

{{ 'forexify-bar.css' | asset_url | stylesheet_tag }}

<div 
  id="forexify-bar" 
  class="forexify-bar forexify-bar--{{ block.settings.position }}" 
  style="background-color: {{ block.settings.bar_color }}; color: {{ block.settings.text_color }};"
  data-shop="{{ shop.permanent_domain }}"
>
  <div class="forexify-bar__content page-width">
    <span class="forexify-bar__title">{{ block.settings.title }}</span>
    
    <div class="forexify-bar__rates" id="forexify-rates">
      <span class="forexify-bar__loading">Loading rates...</span>
    </div>
    
    <span class="forexify-bar__source">ECB</span>
  </div>
</div>

<script>
(function() {
  'use strict';
  
  const shopDomain = document.getElementById('forexify-bar')?.dataset.shop;
  if (!shopDomain) return;
  
  const PROXY_URL = `/apps/forexify/api/forexify`;
  const CURRENCIES = {{ block.settings.currencies | split: ',' | json }};
  const CURRENCY_NAMES = {
    'DKK': '🇩🇰 DKK/EUR',
    'SEK': '🇸🇪 SEK/EUR',
    'USD': '🇺🇸 USD/EUR',
    'GBP': '🇬🇧 GBP/EUR',
    'CHF': '🇨🇭 CHF/EUR',
    'JPY': '🇯🇵 JPY/EUR',
    'NOK': '🇳🇴 NOK/EUR',
    'PLN': '🇵🇱 PLN/EUR',
    'CZK': '🇨🇿 CZK/EUR',
    'HUF': '🇭🇺 HUF/EUR',
    'AUD': '🇦🇺 AUD/EUR',
    'CAD': '🇨🇦 CAD/EUR',
    'NZD': '🇳🇿 NZD/EUR',
    'CNY': '🇨🇳 CNY/EUR',
    'SGD': '🇸🇬 SGD/EUR'
  };
  
  async function fetchRates() {
    try {
      const currencyParam = CURRENCIES.join(',');
      const response = await fetch(`${PROXY_URL}?currencies=${currencyParam}`);
      
      if (!response.ok) throw new Error('Failed to fetch');
      
      const data = await response.json();
      
      if (data.rates) {
        renderRates(data.rates);
      } else {
        showError();
      }
    } catch (error) {
      console.error('Forexify:', error);
      showError();
    }
  }
  
  function renderRates(rates) {
    const container = document.getElementById('forexify-rates');
    if (!container) return;
    
    const ratesHtml = Object.entries(rates)
      .map(([code, rate]) => {
        const label = CURRENCY_NAMES[code] || `${code}/EUR`;
        return `<span class="forexify-bar__rate">${label}: <strong>${rate.toFixed(4)}</strong></span>`;
      })
      .join('');
    
    container.innerHTML = ratesHtml;
  }
  
  function showError() {
    const container = document.getElementById('forexify-rates');
    if (container) {
      container.innerHTML = '<span class="forexify-bar__error">Rates temporarily unavailable</span>';
    }
  }
  
  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fetchRates);
  } else {
    fetchRates();
  }
  
  // Refresh every hour
  setInterval(fetchRates, 3600000);
})();
</script>

{% schema %}
{
  "name": "Forexify Exchange Rate Bar",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Bar Title",
      "default": "Live Exchange Rates"
    },
    {
      "type": "textarea",
      "id": "currencies",
      "label": "Currencies (comma-separated)",
      "default": "DKK,SEK",
      "info": "Available: DKK, SEK, USD, GBP, CHF, JPY, NOK, PLN, CZK, HUF, AUD, CAD, NZD, CNY, SGD"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Bar Position",
      "options": [
        { "value": "top", "label": "Top of page" },
        { "value": "bottom", "label": "Bottom of page" }
      ],
      "default": "top"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
